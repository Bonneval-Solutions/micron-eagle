{
  "id": "page",
  "label": "Page",
  "format": "page",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID",
          "placeholder": ""
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "placeholder": "",
          "allowTargetBlank": true,
          "single": "heading1"
        }
      },
      "section": {
        "type": "Select",
        "config": {
          "label": "Section",
          "placeholder": "Choose section for nav grouping",
          "options": ["Home","Services on-site", "Services and Repairs", "Spare-parts", "About", "Others", "contact"]
        }
      },
      "intro": {
        "type": "StructuredText",
        "config": {
          "label": "Intro / short description",
          "placeholder": "Optional for listing cards",
          "allowTargetBlank": true,
          "single": "paragraph"
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "hero": {
              "type": "SharedSlice"
            },
            "main_pathways": {
              "type": "SharedSlice"
            },
            "core_services": {
              "type": "SharedSlice"
            },
            "industry_applications": {
              "type": "SharedSlice"
            },
            "why_micron_eagle": {
              "type": "SharedSlice"
            },
            "certifications_partners": {
              "type": "SharedSlice"
            },
            "testimonials": {
              "type": "SharedSlice"
            },
            "cta_band": {
              "type": "SharedSlice"
            },
            "rich_text": {
              "type": "SharedSlice"
            },
            "faq": {
              "type": "SharedSlice"
            },
            "team_section": {
              "type": "SharedSlice"
            },
            "blog_grid": {
              "type": "SharedSlice"
            },
            "main_pathways_v2": {
              "type": "SharedSlice"
            },
            "core_services_v2": {
              "type": "SharedSlice"
            },
            "industry_applications_v2": {
              "type": "SharedSlice"
            },
            "why_micron_eagle_v2": {
              "type": "SharedSlice"
            },
            "certifications_partners_v2": {
              "type": "SharedSlice"
            },
            "testimonials_v2": {
              "type": "SharedSlice"
            },
            "cta_band_v2": {
              "type": "SharedSlice"
            },
            "stats_band": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      }
    }
  }
}
